        "    'SkinThickness': 35, 'Insulin': 0, 'BMI': 33.6,\n",
        "    'DiabetesPedigreeFunction': 0.627, 'Age': 50\n",
        "}\n",
        "\n",
        "result = predict(sample)\n",
        "print(\"Smoke test →\", result)"
