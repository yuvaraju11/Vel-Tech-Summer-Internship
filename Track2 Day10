        "def predict(form_data: dict) -> dict:\n",
        "    \"\"\"\n",
        "    Flask-ready predict function.\n",
        "    Loads all .pkl files INSIDE itself — no outside variables needed.\n",
        "\n",
        "    Input  : dict with 8 keys (Pregnancies, Glucose, BloodPressure,\n",
        "                                SkinThickness, Insulin, BMI,\n",
        "                                DiabetesPedigreeFunction, Age)\n",
        "    Output : dict with prediction, confidence, top_features, risk_level\n",
        "    \"\"\"\n",
        "    import joblib\n",
        "    import pandas as pd\n",
        "    import numpy as np\n",
        "\n",
        "    try:\n",
        "        # Step 1 — Load models INSIDE the function\n",
        "        model_p   = joblib.load(\"models/final_model.pkl\")\n",
        "        scaler_p  = joblib.load(\"models/scaler.pkl\")\n",
        "        encoder_p = joblib.load(\"models/label_encoder.pkl\")\n",
        "\n",
        "        # Step 2 — Convert dict to DataFrame\n",
        "        cols = ['Pregnancies', 'Glucose', 'BloodPressure', 'SkinThickness',\n",
        "                'Insulin', 'BMI', 'DiabetesPedigreeFunction', 'Age']\n",
        "        df_input = pd.DataFrame([form_data], columns=cols).astype(float)\n",
        "\n",
        "        # Step 3 — Scale (must scale — same as training)\n",
        "        X_scaled = scaler_p.transform(df_input)\n",
        "\n",
        "        # Step 4 — Predict\n",
        "        pred_num  = model_p.predict(X_scaled)[0]\n",
        "        pred_prob = model_p.predict_proba(X_scaled)[0]\n",
        "\n",
        "        # Step 5 — Build clean return dict\n",
        "        label_str  = \"Diabetic\" if int(pred_num) == 1 else \"Not Diabetic\"\n",
        "        confidence = round(float(max(pred_prob)) * 100, 1)\n",
        "\n",
        "        top_idx   = np.argsort(model_p.feature_importances_)[::-1][:3]\n",
        "        top_feats = [cols[i] for i in top_idx]\n",
        "\n",
        "        if int(pred_num) == 1 and confidence >= 80:\n",
        "            risk_level = \"High\"\n",
        "        elif int(pred_num) == 1:\n",
        "            risk_level = \"Medium\"\n",
        "        else:\n",
        "            risk_level = \"Low\"\n",
        "\n",
        "        return {\n",
        "            \"prediction\":   label_str,\n",
        "            \"confidence\":   f\"{confidence}%\",\n",
        "            \"top_features\": top_feats,\n",
        "            \"risk_level\":   risk_level\n",
        "        }\n",
        "\n",
        "    except Exception as e:\n",
        "        return {\n",
        "            \"error\":      str(e),\n",
        "            \"prediction\": None,\n",
        "            \"confidence\": \"N/A\",\n",
        "            \"risk_level\": None\n",
        "        }\n",
        "\n",
        "\n",
        "# ── Smoke test ──────────────────────────────────────────────\n",
        "sample = {\n",
